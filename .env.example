# ------------------------------------------------------------
# Application identity and runtime
# ------------------------------------------------------------
APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_MAINTENANCE_DRIVER=file

# Password hashing cost (increase in production if needed)
BCRYPT_ROUNDS=12

# ------------------------------------------------------------
# Project metadata and branding
# ------------------------------------------------------------
APP_PROJECT_NAME=Zephyr
# Browser tab icon (SVG variant, scalable)
APP_FAVICON="images/favicon.svg"
# SVG favicon path (preferred for modern browsers)
APP_FAVICON_SVG="images/favicon.svg"
# PNG favicon path (recommended 32x32)
APP_FAVICON_PNG_32="images/favicon.png"
# ICO favicon path (recommended multi-size: 16x16, 32x32, 48x48)
APP_FAVICON_ICO="images/favicon.ico"
# Apple touch icon path (PNG, recommended 180x180)
APP_APPLE_TOUCH_ICON="images/favicon_180x180.png"
APP_LOGO="images/logo.svg"

# Technical diagnostics in user menu (admin only)
APP_DIAGNOSTICS_ENABLED=true

# ------------------------------------------------------------
# Localization and date/time display
# ------------------------------------------------------------
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
LOCALE=en
FALLBACK_LOCALE=en
CALENDAR_TIMEZONE=UTC
DATE_FORMAT=Y-m-d
DATETIME_FORMAT="Y-m-d H:i"

# ------------------------------------------------------------
# Bootstrap admin account (created by seeding)
# ------------------------------------------------------------
BOOTSTRAP_ADMIN_NAME="Admin"
BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
BOOTSTRAP_ADMIN_PASSWORD=password

# Load demo records during setup/seeding (true/false)
SEED_DEMO_DATA=false

# ------------------------------------------------------------
# Work schedule defaults (1=Mon ... 7=Sun)
# ------------------------------------------------------------
ZPH_TIME_START_WORK=09:00
ZPH_TIME_END_WORK=17:00
ZPH_WORK_DAYS=1,2,3,4,5

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ------------------------------------------------------------
# Database connection
# ------------------------------------------------------------
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zephyr
DB_USERNAME=zephyr
DB_PASSWORD=password

# ------------------------------------------------------------
# Core drivers
# ------------------------------------------------------------
BROADCAST_CONNECTION=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SCOPE_DELETE_GRACE_HOURS=24

# ------------------------------------------------------------
# Cache/queue backends
# ------------------------------------------------------------
MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ------------------------------------------------------------
# Mail transport
# ------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------
# Optional AWS storage settings
# ------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ------------------------------------------------------------
# Optional realtime (Pusher)
# ------------------------------------------------------------
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# ------------------------------------------------------------
# Frontend runtime exposure (Vite)
# ------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
