# ------------------------------------------------------------
# Docker deployment template — copy to .env and customize
# ------------------------------------------------------------
APP_NAME=Zephyr
APP_ENV=production
APP_KEY=                          # fill with: php artisan key:generate --show
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_PORT=8080

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ------------------------------------------------------------
# Project metadata and branding
# ------------------------------------------------------------
APP_PROJECT_NAME=Zephyr
APP_FAVICON="images/favicon.svg"
APP_FAVICON_SVG="images/favicon.svg"
APP_FAVICON_PNG_32="images/favicon.png"
APP_FAVICON_ICO="images/favicon.ico"
APP_APPLE_TOUCH_ICON="images/favicon_180x180.png"
APP_LOGO="images/logo.svg"

APP_DIAGNOSTICS_ENABLED=false

# ------------------------------------------------------------
# Localization
# ------------------------------------------------------------
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
LOCALE=en
FALLBACK_LOCALE=en
CALENDAR_TIMEZONE=UTC
DATE_FORMAT=Y-m-d
DATETIME_FORMAT="Y-m-d H:i"

# ------------------------------------------------------------
# Bootstrap admin account
# ------------------------------------------------------------
BOOTSTRAP_ADMIN_NAME="Admin"
BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
BOOTSTRAP_ADMIN_PASSWORD=change-me-in-production
SEED_DEMO_DATA=false

# ------------------------------------------------------------
# Work schedule defaults
# ------------------------------------------------------------
ZPH_TIME_START_WORK=09:00
ZPH_TIME_END_WORK=17:00
ZPH_WORK_DAYS=1,2,3,4,5

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ------------------------------------------------------------
# Database — host must match the db service name in Compose
# ------------------------------------------------------------
DB_CONNECTION=mariadb
DB_HOST=db
DB_PORT=3306
DB_DATABASE=zephyr
DB_USERNAME=zephyr
DB_PASSWORD=change-me-in-production
DB_ROOT_PASSWORD=change-me-in-production

# ------------------------------------------------------------
# Redis — host must match the redis service name in Compose
# ------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ------------------------------------------------------------
# Core drivers — use Redis in production
# ------------------------------------------------------------
BROADCAST_CONNECTION=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

SCOPE_DELETE_GRACE_HOURS=24

# ------------------------------------------------------------
# Mail
# ------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------
# Optional AWS storage
# ------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
